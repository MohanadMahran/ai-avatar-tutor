# ==============================================================================
# AI Avatar Tutor — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required API keys are marked with [REQUIRED].
# All other variables have sensible defaults and are optional.
# ==============================================================================

# ------------------------------------------------------------------------------
# Groq API — LLM Provider  [REQUIRED]
# Get your key at: https://console.groq.com/keys
# ------------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ------------------------------------------------------------------------------
# ElevenLabs API — Speech-to-Text  [REQUIRED]
# Get your key at: https://elevenlabs.io/api
# ------------------------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ------------------------------------------------------------------------------
# HeyGen API — Avatar Video Generation  [OPTIONAL]
# Get your key at: https://app.heygen.com/settings/api
# If not configured, the app works in text-only mode (no avatar video).
# ------------------------------------------------------------------------------
HEYGEN_API_KEY=your_heygen_api_key_here
HEYGEN_AVATAR_ID=your_avatar_id_here
HEYGEN_VOICE_ID=your_heygen_voice_id_here

# ------------------------------------------------------------------------------
# RAG Settings
# ------------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # HuggingFace model for embeddings
VECTOR_STORE_PATH=./vector_store                          # FAISS index storage location
DOCS_PATH=./docs                                         # Directory for source documents
CHUNK_SIZE=500                                            # Characters per document chunk
CHUNK_OVERLAP=50                                          # Overlap between consecutive chunks
TOP_K_RESULTS=4                                           # Number of top results to retrieve
RELEVANCE_THRESHOLD=0.3                                   # Minimum similarity score (0.0–1.0)

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
APP_HOST=0.0.0.0                  # Server bind address
APP_PORT=8000                     # Server port
DEBUG=true                        # Enable debug mode with auto-reload
MAX_CONVERSATION_HISTORY=10       # Max conversation turns before summarization

# ------------------------------------------------------------------------------
# Audio Settings
# ------------------------------------------------------------------------------
AUDIO_SAMPLE_RATE=16000            # Sample rate in Hz
AUDIO_CHANNELS=1                   # Mono audio
MAX_AUDIO_DURATION_SECONDS=60      # Max recording length in seconds

# ------------------------------------------------------------------------------
# Cache Settings
# ------------------------------------------------------------------------------
ENABLE_CACHE=true                  # Cache identical query responses
CACHE_TTL_SECONDS=3600             # Cache expiry time (1 hour)